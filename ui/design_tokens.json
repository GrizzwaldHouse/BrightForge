{
  "version": "1.0.0",
  "description": "Design tokens for BrightForge 3D Editor UI. All components use these values for consistency.",
  "colors": {
    "background": {
      "primary": "#1E1E2E",
      "secondary": "#2A2A3E",
      "tertiary": "#363650",
      "elevated": "#3C3C54",
      "overlay": "#1E1E2EE6"
    },
    "text": {
      "primary": "#FFFFFF",
      "secondary": "#B0B0C0",
      "tertiary": "#808090",
      "disabled": "#505060",
      "inverse": "#1E1E2E"
    },
    "border": {
      "primary": "#505060",
      "secondary": "#3C3C4C",
      "focus": "#7C3AED",
      "error": "#EF4444",
      "success": "#10B981"
    },
    "accent": {
      "primary": "#7C3AED",
      "hover": "#8B5CF6",
      "active": "#6D28D9",
      "disabled": "#5B21B6"
    },
    "status": {
      "success": "#10B981",
      "successBg": "#10B98133",
      "warning": "#F59E0B",
      "warningBg": "#F59E0B33",
      "error": "#EF4444",
      "errorBg": "#EF444433",
      "info": "#3B82F6",
      "infoBg": "#3B82F633"
    },
    "gizmo": {
      "xAxis": "#EF4444",
      "yAxis": "#10B981",
      "zAxis": "#3B82F6",
      "xAxisHover": "#F87171",
      "yAxisHover": "#34D399",
      "zAxisHover": "#60A5FA",
      "selected": "#FBBF24"
    },
    "viewport": {
      "background": "#1E1E2E",
      "grid": "#3C3C4C",
      "gridMajor": "#505060",
      "axis": "#FFFFFF",
      "selection": "#7C3AED"
    },
    "panel": {
      "header": "#2A2A3E",
      "headerHover": "#363650",
      "splitter": "#505060",
      "splitterHover": "#7C3AED",
      "splitterActive": "#8B5CF6"
    }
  },
  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "xxl": 48
  },
  "radius": {
    "none": 0,
    "sm": 4,
    "md": 8,
    "lg": 12,
    "xl": 16,
    "full": 9999
  },
  "typography": {
    "fontFamily": {
      "primary": "Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
      "monospace": "'JetBrains Mono', 'Consolas', 'Monaco', 'Courier New', monospace"
    },
    "fontSize": {
      "xs": 10,
      "sm": 12,
      "md": 14,
      "lg": 16,
      "xl": 20,
      "xxl": 24,
      "xxxl": 32
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.2,
      "normal": 1.5,
      "loose": 1.75
    }
  },
  "shadows": {
    "none": "none",
    "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.5)",
    "md": "0 4px 6px -1px rgba(0, 0, 0, 0.5), 0 2px 4px -1px rgba(0, 0, 0, 0.3)",
    "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.5), 0 4px 6px -2px rgba(0, 0, 0, 0.3)",
    "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.5), 0 10px 10px -5px rgba(0, 0, 0, 0.2)",
    "inner": "inset 0 2px 4px 0 rgba(0, 0, 0, 0.5)"
  },
  "animation": {
    "duration": {
      "fast": 150,
      "normal": 250,
      "slow": 350
    },
    "easing": {
      "easeIn": "cubic-bezier(0.4, 0, 1, 1)",
      "easeOut": "cubic-bezier(0, 0, 0.2, 1)",
      "easeInOut": "cubic-bezier(0.4, 0, 0.2, 1)",
      "linear": "linear"
    }
  },
  "zIndex": {
    "base": 0,
    "dropdown": 100,
    "modal": 200,
    "tooltip": 300,
    "gizmo": 400,
    "menu": 500
  },
  "sizing": {
    "menuBar": {
      "height": 40
    },
    "statusBar": {
      "height": 24
    },
    "toolPanel": {
      "width": 200,
      "minWidth": 150,
      "maxWidth": 400
    },
    "propertyInspector": {
      "width": 300,
      "minWidth": 200,
      "maxWidth": 500
    },
    "assetBrowser": {
      "height": 250,
      "minHeight": 100,
      "maxHeight": 600
    },
    "dragDropZone": {
      "height": 150
    },
    "fileSearchBox": {
      "height": 36
    },
    "splitter": {
      "hitTarget": 4,
      "visualWidth": 1
    },
    "panelHeader": {
      "height": 32,
      "collapsedWidth": 24
    },
    "thumbnail": {
      "small": 32,
      "medium": 64,
      "large": 128,
      "xlarge": 256
    },
    "button": {
      "height": 32,
      "heightSm": 24,
      "heightLg": 40
    },
    "input": {
      "height": 32,
      "heightSm": 24,
      "heightLg": 40
    },
    "icon": {
      "xs": 12,
      "sm": 16,
      "md": 20,
      "lg": 24,
      "xl": 32
    }
  },
  "components": {
    "button": {
      "primary": {
        "background": "#7C3AED",
        "backgroundHover": "#8B5CF6",
        "backgroundActive": "#6D28D9",
        "backgroundDisabled": "#5B21B6",
        "text": "#FFFFFF",
        "textDisabled": "#B0B0C0",
        "border": "none",
        "borderRadius": 8,
        "paddingX": 16,
        "paddingY": 8,
        "fontSize": 14,
        "fontWeight": 500
      },
      "secondary": {
        "background": "transparent",
        "backgroundHover": "#2A2A3E",
        "backgroundActive": "#363650",
        "backgroundDisabled": "transparent",
        "text": "#B0B0C0",
        "textHover": "#FFFFFF",
        "textDisabled": "#505060",
        "border": "1px solid #505060",
        "borderHover": "1px solid #7C3AED",
        "borderRadius": 8,
        "paddingX": 16,
        "paddingY": 8,
        "fontSize": 14,
        "fontWeight": 500
      },
      "icon": {
        "background": "transparent",
        "backgroundHover": "#2A2A3E",
        "backgroundActive": "#363650",
        "text": "#B0B0C0",
        "textHover": "#FFFFFF",
        "border": "none",
        "borderRadius": 8,
        "size": 32,
        "iconSize": 20
      },
      "tool": {
        "background": "transparent",
        "backgroundHover": "#2A2A3E",
        "backgroundSelected": "#7C3AED",
        "backgroundSelectedHover": "#8B5CF6",
        "text": "#B0B0C0",
        "textHover": "#FFFFFF",
        "textSelected": "#FFFFFF",
        "border": "1px solid #505060",
        "borderSelected": "1px solid #7C3AED",
        "borderRadius": 8,
        "paddingX": 12,
        "paddingY": 8,
        "fontSize": 14,
        "fontWeight": 500
      }
    },
    "input": {
      "text": {
        "background": "#2A2A3E",
        "backgroundFocus": "#363650",
        "backgroundDisabled": "#1E1E2E",
        "text": "#FFFFFF",
        "textPlaceholder": "#808090",
        "textDisabled": "#505060",
        "border": "1px solid #505060",
        "borderFocus": "1px solid #7C3AED",
        "borderError": "1px solid #EF4444",
        "borderRadius": 8,
        "paddingX": 12,
        "paddingY": 8,
        "fontSize": 14,
        "fontWeight": 400
      },
      "number": {
        "background": "#2A2A3E",
        "backgroundFocus": "#363650",
        "backgroundDisabled": "#1E1E2E",
        "text": "#FFFFFF",
        "textPlaceholder": "#808090",
        "textDisabled": "#505060",
        "border": "1px solid #505060",
        "borderFocus": "1px solid #7C3AED",
        "borderError": "1px solid #EF4444",
        "borderRadius": 8,
        "paddingX": 12,
        "paddingY": 8,
        "fontSize": 14,
        "fontWeight": 500,
        "fontFamily": "'JetBrains Mono', 'Consolas', 'Monaco', 'Courier New', monospace"
      },
      "slider": {
        "track": "#505060",
        "trackFill": "#7C3AED",
        "thumb": "#FFFFFF",
        "thumbHover": "#F3F4F6",
        "thumbActive": "#E5E7EB",
        "thumbBorder": "#7C3AED",
        "height": 4,
        "thumbSize": 16,
        "borderRadius": 9999
      }
    },
    "checkbox": {
      "background": "#2A2A3E",
      "backgroundChecked": "#7C3AED",
      "backgroundHover": "#363650",
      "backgroundDisabled": "#1E1E2E",
      "border": "1px solid #505060",
      "borderChecked": "1px solid #7C3AED",
      "borderFocus": "1px solid #7C3AED",
      "checkmark": "#FFFFFF",
      "borderRadius": 4,
      "size": 20
    },
    "panel": {
      "background": "#2A2A3E",
      "header": {
        "background": "#1E1E2E",
        "backgroundHover": "#2A2A3E",
        "text": "#FFFFFF",
        "textSecondary": "#B0B0C0",
        "border": "1px solid #505060",
        "borderRadius": 0,
        "paddingX": 12,
        "paddingY": 8,
        "fontSize": 14,
        "fontWeight": 600,
        "height": 32
      },
      "section": {
        "background": "#2A2A3E",
        "backgroundHover": "#363650",
        "headerBackground": "#1E1E2E",
        "headerBackgroundHover": "#2A2A3E",
        "text": "#FFFFFF",
        "textSecondary": "#B0B0C0",
        "border": "1px solid #505060",
        "borderRadius": 8,
        "paddingX": 12,
        "paddingY": 8,
        "fontSize": 14,
        "fontWeight": 500
      }
    },
    "menu": {
      "background": "#2A2A3E",
      "itemBackground": "transparent",
      "itemBackgroundHover": "#363650",
      "itemBackgroundActive": "#7C3AED",
      "itemBackgroundDisabled": "transparent",
      "text": "#FFFFFF",
      "textSecondary": "#B0B0C0",
      "textDisabled": "#505060",
      "border": "1px solid #505060",
      "borderRadius": 8,
      "shadow": "0 10px 15px -3px rgba(0, 0, 0, 0.5), 0 4px 6px -2px rgba(0, 0, 0, 0.3)",
      "paddingX": 8,
      "paddingY": 4,
      "itemPaddingX": 12,
      "itemPaddingY": 8,
      "fontSize": 14,
      "fontWeight": 400
    },
    "tooltip": {
      "background": "#1E1E2E",
      "text": "#FFFFFF",
      "border": "1px solid #505060",
      "borderRadius": 8,
      "shadow": "0 4px 6px -1px rgba(0, 0, 0, 0.5), 0 2px 4px -1px rgba(0, 0, 0, 0.3)",
      "paddingX": 8,
      "paddingY": 4,
      "fontSize": 12,
      "fontWeight": 400,
      "maxWidth": 250
    },
    "scrollbar": {
      "track": "#1E1E2E",
      "thumb": "#505060",
      "thumbHover": "#808090",
      "thumbActive": "#B0B0C0",
      "width": 12,
      "borderRadius": 6
    },
    "contextMenu": {
      "background": "#2A2A3E",
      "itemBackground": "transparent",
      "itemBackgroundHover": "#363650",
      "itemBackgroundActive": "#7C3AED",
      "separator": "#505060",
      "text": "#FFFFFF",
      "textSecondary": "#B0B0C0",
      "border": "1px solid #505060",
      "borderRadius": 8,
      "shadow": "0 10px 15px -3px rgba(0, 0, 0, 0.5), 0 4px 6px -2px rgba(0, 0, 0, 0.3)",
      "paddingX": 4,
      "paddingY": 4,
      "itemPaddingX": 12,
      "itemPaddingY": 8,
      "fontSize": 14,
      "fontWeight": 400
    },
    "dragDropZone": {
      "background": "#2A2A3E",
      "backgroundDragOver": "#7C3AED1A",
      "backgroundUploading": "#2A2A3E",
      "backgroundSuccess": "#10B9811A",
      "backgroundError": "#EF44441A",
      "border": "2px dashed #505060",
      "borderDragOver": "3px dashed #7C3AED",
      "borderUploading": "2px solid #7C3AED",
      "borderSuccess": "2px solid #10B981",
      "borderError": "2px solid #EF4444",
      "borderRadius": 8,
      "text": "#B0B0C0",
      "textSecondary": "#808090",
      "icon": "#7C3AED",
      "iconSuccess": "#10B981",
      "iconError": "#EF4444",
      "paddingX": 24,
      "paddingY": 24,
      "fontSize": 14,
      "fontWeight": 400
    },
    "progressBar": {
      "background": "#1E1E2E",
      "fill": "#7C3AED",
      "fillSuccess": "#10B981",
      "fillError": "#EF4444",
      "text": "#FFFFFF",
      "border": "1px solid #505060",
      "borderRadius": 9999,
      "height": 8
    },
    "fileList": {
      "item": {
        "background": "transparent",
        "backgroundHover": "#363650",
        "backgroundSelected": "#7C3AED33",
        "backgroundSelectedHover": "#7C3AED4D",
        "border": "1px solid transparent",
        "borderSelected": "1px solid #7C3AED",
        "borderRadius": 8,
        "text": "#FFFFFF",
        "textSecondary": "#B0B0C0",
        "paddingX": 8,
        "paddingY": 8,
        "fontSize": 14,
        "fontWeight": 400
      },
      "grid": {
        "gap": 8,
        "columns": 4
      },
      "list": {
        "gap": 4,
        "rowHeight": 40
      }
    }
  }
}
