{
  "name": "brightforge",
  "version": "4.2.0",
  "description": "BrightForge - Hybrid developer coding + design + 3D generation agent with local LLMs, cloud fallback, and GPU-accelerated mesh generation",
  "main": "bin/brightforge.js",
  "type": "module",
  "bin": {
    "brightforge": "./bin/brightforge.js",
    "brightforge-server": "./bin/brightforge-server.js",
    "brightforge-desktop": "./bin/brightforge-desktop.js",
    "llcapp": "./bin/llcapp.js",
    "llcapp-server": "./bin/llcapp-server.js",
    "llcapp-desktop": "./bin/llcapp-desktop.js"
  },
  "scripts": {
    "start": "node bin/brightforge.js",
    "test-llm": "node src/core/llm-client.js --test",
    "test-plan": "node src/core/plan-engine.js --test",
    "test-context": "node src/core/file-context.js --test",
    "test-diff": "node src/core/diff-applier.js --test",
    "test-session": "node src/core/session-log.js --test",
    "test-terminal": "node src/ui/terminal.js --test",
    "test-image": "node src/core/image-client.js --test",
    "test-design": "node src/core/design-engine.js --test",
    "test": "npm run test-all-core && npm run test-multi-model",
    "test-all-core": "npm run test-llm && npm run test-plan && npm run test-context && npm run test-diff && npm run test-session && npm run test-image && npm run test-design",
    "lint": "eslint src/ public/js/ bin/ --ext .js",
    "lint:fix": "eslint src/ public/js/ bin/ --ext .js --fix",
    "chat": "node bin/brightforge.js --chat",
    "test-history": "node src/core/message-history.js --test",
    "test-conversation": "node src/core/conversation-session.js --test",
    "test-multi-step": "node src/core/multi-step-planner.js --test",
    "server": "node bin/brightforge-server.js",
    "test-api": "node src/api/web-session.js --test",
    "dev": "node bin/brightforge-server.js",
    "desktop": "node bin/brightforge-desktop.js",
    "build-desktop": "cd desktop && electron-builder",
    "test-bridge": "node src/forge3d/model-bridge.js --test",
    "test-forge-session": "node src/forge3d/forge-session.js --test",
    "test-forge-db": "node src/forge3d/database.js --test",
    "test-project-manager": "node src/forge3d/project-manager.js --test",
    "test-queue": "node src/forge3d/generation-queue.js --test",
    "test-downloader": "node src/forge3d/model-downloader.js --test",
    "test-config": "node src/forge3d/config-loader.js --test",
    "test-monitor": "node src/forge3d/monitor.js --test",
    "test-fbx-converter": "python python/fbx_converter.py --test",
    "test-orch-db": "node src/orchestration/storage.js --test",
    "test-event-bus": "node src/orchestration/event-bus.js --test",
    "test-task-state": "node src/orchestration/task-state.js --test",
    "test-supervisor": "node src/orchestration/supervisor.js --test",
    "test-handoff": "node src/orchestration/handoff.js --test",
    "test-orchestrator": "node src/orchestration/index.js --test",
    "test-multi-model": "node src/forge3d/test-multi-model.js --test",
    "test-pipeline": "node src/forge3d/pipeline/test-pipeline.js --test",
    "test-scene-graph": "node src/forge3d/scene/scene-graph.js --test",
    "test-scene-analyzer": "node src/forge3d/scene/scene-analyzer.js --test",
    "test-scene-routes": "node src/api/routes/scene.js --test",
    "test-world-graph": "node src/forge3d/world/world-graph.js --test",
    "test-world-analyzer": "node src/forge3d/world/world-analyzer.js --test",
    "test-npc-generator": "node src/forge3d/gameplay/npc-generator.js --test",
    "test-interaction-generator": "node src/forge3d/gameplay/interaction-generator.js --test",
    "test-quest-generator": "node src/forge3d/gameplay/quest-generator.js --test",
    "test-logic-builder": "node src/forge3d/gameplay/game-logic-builder.js --test",
    "test-biome-generator": "node src/forge3d/world/biome-generator.js --test",
    "test-streaming-layout": "node src/forge3d/world/streaming-layout.js --test",
    "test-world-routes": "node src/api/routes/world.js --test",
    "test-prototype-routes": "node src/api/routes/prototype.js --test",
    "test-integration": "node src/tests/integration-suite.js",
    "test-stability": "node src/tests/stability-run.js",
    "test-stability-quick": "node src/tests/stability-run.js --quick",
    "test-model-config": "node src/model-intelligence/config-loader.js --test",
    "test-model-db": "node src/model-intelligence/database.js --test",
    "test-model-events": "node src/model-intelligence/event-types.js --test",
    "test-model-scanner": "node src/model-intelligence/scanner.js --test",
    "test-model-writer": "node src/model-intelligence/inventory-writer.js --test",
    "test-model-intel": "node src/model-intelligence/index.js --test",
    "test-model-router": "node src/model-intelligence/model-router.js --test",
    "test-model-scanner-py": "py -3 python/model_scanner.py --test",
    "test-idea-ingestion": "node src/idea/idea-ingestion.js --test",
    "test-idea-classifier": "node src/idea/idea-classifier.js --test",
    "test-idea-scoring": "node src/idea/idea-scoring.js --test",
    "test-idea-research": "node src/idea/research-agent.js --test",
    "test-idea-indexer": "node src/idea/idea-indexer.js --test",
    "test-idea-pipeline": "node src/idea/test-pipeline.js --test"
  },
  "keywords": [
    "coding-agent",
    "llm",
    "ollama",
    "hybrid-ai",
    "developer-tools",
    "plan-review-run"
  ],
  "author": "Marcus Daley <github.com/GrizzwaldHouse>",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "obs-websocket-js": "^5.0.8",
    "rotating-file-stream": "^3.2.9",
    "undici": "^7.22.0",
    "ws": "^8.20.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
